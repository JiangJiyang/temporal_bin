{
  "test_mode": true,
  "minio": {
    "endpoint": "",
    "sdk_endpoint": "",
    "access_key": "",
    "secret_key": "",
    "bucket": "",
    "source_prefix": "测试项目",
    "result_prefix": "results",
    "allow_local_fallback": true,
    "prefer_remote_in_test": false,
    "strict_backup_in_production": false
  },
  "api_model": {
    "enabled": true,
    "base_url": "<REPLACE_WITH_YOUR_QWEN_GATEWAY_BASE_URL>",
    "api_key": "<REPLACE_WITH_YOUR_QWEN_GATEWAY_API_KEY>",
    "model": "Qwen3-235B-int8",
    "temperature": 0.0,
    "max_tokens": 512,
    "timeout_seconds": 60
  },
  "local_model": {
    "enabled": false,
    "base_url": "",
    "api_key": "",
    "model": "Qwen3-235B-int8",
    "temperature": 0.0,
    "max_tokens": 512,
    "timeout_seconds": 30
  },
  "ocr": {
    "enabled": true,
    "backend": "rapidocr",
    "dpi": 300,
    "max_pdf_pages": 8,
    "max_excel_rows": 30,
    "max_excel_cols": 12,
    "max_front_chars": 4000,
    "title_scan_lines": 80,
    "only_when_text_empty": true,
    "min_chars_to_skip_ocr": 80
  },
  "logging": {
    "level": "INFO"
  },
  "output": {
    "tag_filename": "tag.json",
    "persist_single_mode": false,
    "indent": 2,
    "ensure_ascii": false
  },
  "paths": {
    "code_root": ".",
    "data_root": ".",
    "local_test_root": "./测试项目",
    "prompt_path": "./prompt.json",
    "filejsonrst_path": "./filejsonrst.json"
  }
}